    {
      "id": 1,
      "type": "barchart",
      "title": "Decisions per day (executed vs not)",
      "description": "See docs/knowledge-base/part6-operational.md § 3.10",
      "datasource": {"type": "postgres", "uid": "QuestDB"},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 0},
      "interval": "auto",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "axisPlacement": "auto",
            "fillOpacity": 80,
            "lineWidth": 1
          },
          "unit": "none",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true},
        "orientation": "vertical",
        "stacking": "normal",
        "tooltip": {"mode": "multi", "sort": "none"},
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 100
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "QuestDB"},
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT date_trunc('day', ts) AS day,\n       SUM(CASE WHEN executed = true  THEN 1 ELSE 0 END) AS executed,\n       SUM(CASE WHEN executed = false THEN 1 ELSE 0 END) AS rejected\n  FROM gateway_actions\n WHERE $__timeFilter(ts)\n GROUP BY day\n ORDER BY day"
        }
      ]
    },
    {
      "id": 2,
      "type": "table",
      "title": "Reject reasons (count)",
      "description": "See docs/knowledge-base/part6-operational.md § 3.10",
      "datasource": {"type": "postgres", "uid": "QuestDB"},
      "gridPos": {"h": 9, "w": 6, "x": 12, "y": 0},
      "interval": "auto",
      "fieldConfig": {
        "defaults": {
          "custom": {"align": "auto", "displayMode": "auto"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}
        },
        "overrides": []
      },
      "options": {"showHeader": true, "cellHeight": "sm", "footer": {"show": false}},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "QuestDB"},
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT reject_reason, COUNT(*) AS n\n  FROM gateway_actions\n WHERE executed = false AND $__timeFilter(ts)\n GROUP BY reject_reason\n ORDER BY n DESC"
        }
      ]
    },
