# =============================================================================
# JuniAuto environment
# Copy to .env and fill in.  NEVER commit .env.
# =============================================================================

# --- Alpaca ------------------------------------------------------------------
# Set ALPACA_PAPER=true for the paper account (default, safe) or false for live.
# The system reads the matching key pair automatically and picks the right
# base URL. The unused pair may stay empty.
ALPACA_PAPER=true

# Paper credentials (used when ALPACA_PAPER=true)
ALPACA_PAPER_API_KEY=
ALPACA_PAPER_SECRET_KEY=

# Live credentials (used ONLY when ALPACA_PAPER=false — real money)
ALPACA_LIVE_API_KEY=
ALPACA_LIVE_SECRET_KEY=

# Alpaca data feed: iex (15-min delayed, free) is the only supported feed;
# the whole model is calibrated around the IEX delay (see PRINCIPLESLONG.md §2.27).
ALPACA_FEED=iex

# --- QuestDB (used inside the Docker network) --------------------------------
DB_HOST=questdb
DB_PORT=8812
DB_USER=admin
DB_PASSWORD=quest
DB_NAME=qdb

# --- Grafana -----------------------------------------------------------------
GRAFANA_PASSWORD=admin
GRAFANA_QUESTDB_PW=quest

# --- Logging / misc ----------------------------------------------------------
LOG_LEVEL=INFO

# Cash-yield fallback used by cash_waiting_value_bps (PRINCIPLESLONG.md §2.24)
FED_FUNDS_RATE=0.045

# =============================================================================
# Host-side port map (all uncommon 31xxx-range; container-side ports are
# unchanged so the internal Docker network stays on defaults):
#
#   Grafana web UI      -> http://localhost:31300
#   Prometheus web UI   -> http://localhost:31090
#   Engine metrics      -> http://localhost:31091/metrics
#   QuestDB PG wire     -> localhost:31812   (psql -h localhost -p 31812 -U admin qdb)
#   QuestDB web console -> http://localhost:31900
#   QuestDB ILP ingest  -> localhost:31909   (client-side ingest from host)
# =============================================================================
