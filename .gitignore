# =============================================================================
# NOTE ON PATTERNS
# Directory names without a leading slash match at ANY depth in the tree.
# `data/` alone would silently drop engine/src/data/, orchestrator/juniauto/data/
# and engine/include/juniauto/data/ — which are all real source dirs.
# Anything meant to match only at the repo root uses a leading slash: /data/.
# =============================================================================

# --- Secrets & env ---
.env
.env.*
!.env.example
*.pem
*.key

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.venv/
/venv/
/env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
/htmlcov/
/dist/
*.so
!engine/**/*.so

# --- C++ / CMake ---
engine/build/
engine/cmake-build-*/
engine/**/*.o
engine/**/*.obj
engine/**/*.a
engine/**/*.dylib
engine/**/*.dll
engine/**/*.exe
CMakeCache.txt
CMakeFiles/
CMakeUserPresets.json
compile_commands.json

# --- Runtime data & artifacts (root-only; anchored with leading slash) ---
/data/
/logs/
/cache/
/grafana-data/
/prometheus-data/
/questdb/
*.parquet
*.duckdb

# --- Editor / OS ---
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# --- Docker ---
docker-compose.override.yml

# --- Third-party spec sources (not redistributable in this public repo) ---
/PRINCIPLESLONG.md
/instructions.md

# --- Local Claude Code / editor harness settings ---
/.claude/
